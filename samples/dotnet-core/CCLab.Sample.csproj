<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>CCLab.Sample</RootNamespace>
    <AssemblyName>CCLab.Sample</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <!-- Spectre.Console powers the first-run boot sequence. The colored
         panel + glow + DON'T PANIC banner would be 80 lines of fragile
         escape-string formatting otherwise. -->
    <PackageReference Include="Spectre.Console" Version="0.49.1" />
  </ItemGroup>

</Project>
